# Application
NODE_ENV=development
PORT=3000
APP_URL=http://localhost:3000
API_URL=http://localhost:3000/api/v1

# Database
DATABASE_URL=postgresql://saas:saas@localhost:5432/saas_dev
DATABASE_POOL_SIZE=10

# Redis (sessions, rate limiting, cache, feature flags)
REDIS_URL=redis://localhost:6379

# Authentication
AUTH_STRATEGY=session
JWT_SECRET=change-me-in-production
SESSION_SECRET=change-me-in-production
SESSION_TTL_SECONDS=3600
REFRESH_TOKEN_TTL_SECONDS=604800

# Multi-Tenancy
TENANCY_MODEL=row_level
# Options: row_level, schema_per_tenant, database_per_tenant

# Billing (Stripe)
PAYMENT_PROVIDER=stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PUBLISHABLE_KEY=pk_test_...

# Feature Flags
FLAG_PROVIDER=database
# Options: database, launchdarkly, unleash

# Rate Limiting
RATE_LIMIT_STORE=redis
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_DEFAULT=60

# Object Storage
S3_BUCKET=saas-uploads-dev
S3_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=

# Email
SMTP_HOST=localhost
SMTP_PORT=1025
SMTP_FROM=noreply@localhost

# Logging
LOG_LEVEL=debug
AUDIT_LOG_RETENTION_DAYS=365

# Encryption
ENCRYPTION_KEY=change-me-in-production-32-bytes
