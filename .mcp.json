{
  "mcpServers": {
    "context7": {
      "command": "npx",
      "args": ["@upstash/context7-mcp@2.1.3"]
    },
    "filesystem": {
      "command": "npx",
      "args": ["@modelcontextprotocol/server-filesystem@2026.1.14", "."]
    },
    "websearch": {
      "command": "npx",
      "args": ["@zhafron/mcp-web-search@1.2.2"]
    },
    "chrome-devtools": {
      "command": "npx",
      "args": ["chrome-devtools-mcp@0.19.0"]
    },
    "omg-memory": {
      "type": "http",
      "url": "http://127.0.0.1:8765/mcp"
    },
    "omg-control": {
      "command": "python3",
      "args": [
        "-m",
        "runtime.omg_mcp_server"
      ]
    }
  }
}
