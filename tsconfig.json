{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "strict": true,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "noEmit": true,
    "types": ["bun-types", "node"]
  },
  "include": ["hooks/**/*.ts", "runtime/**/*.ts", "scripts/**/*.ts", "tests/**/*.ts"]
}
