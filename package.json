{
  "name": "@trac3r/oh-my-god",
  "version": "3.0.0",
  "description": "OMG (Oh My God) — Multi-agent orchestration, evidence-backed verification, and durable session state for Claude Code, Codex, and supported agent hosts",
  "type": "module",
  "main": "src/index.ts",
  "bin": {
    "omg": "src/cli/index.ts",
    "omg-control": "src/mcp/server.ts"
  },
  "files": [
    "src/",
    "dist/",
    "runtime/",
    "registry/",
    "hooks/",
    "commands/",
    "agents/",
    "lab/",
    "plugins/",
    "tools/",
    "hud/",
    "docs/install/",
    "docs/proof.md",
    "docs/command-surface.md",
    "README.md",
    "QUICK-REFERENCE.md",
    "INSTALL-VERIFICATION-INDEX.md",
    "OMG-setup.sh",
    "settings.json",
    "pyproject.toml",
    "CHANGELOG.md"
  ],
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src/ --ext .ts",
    "build": "bun build src/index.ts --outdir dist --target bun",
    "omg": "bun run src/cli/index.ts",
    "omg-control": "bun run src/mcp/server.ts",
    "eval": "bun run src/eval/runner.ts",
    "benchmark": "bun run src/benchmarks/runner.ts",
    "validate-skills": "bun run src/skills/validator.ts",
    "postinstall": "echo 'OMG v3.0.0-rc installed. Run: bunx omg install --plan'"
  },
  "keywords": [
    "claude",
    "claude-code",
    "orchestration",
    "multi-agent",
    "ai",
    "llm",
    "codex",
    "gemini"
  ],
  "author": "trac3r00",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/trac3r00/OMG.git"
  },
  "bugs": {
    "url": "https://github.com/trac3r00/OMG/issues"
  },
  "homepage": "https://github.com/trac3r00/OMG#readme",
  "engines": {
    "bun": ">=1.1.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.11",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.6.0",
    "@types/proper-lockfile": "^4.1.4",
    "@types/yargs": "^17.0.35",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "eslint": "^10.1.0",
    "prettier": "^3.8.1",
    "typescript": "^6.0.2"
  },
  "dependencies": {
    "@iarna/toml": "^2.2.5",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "js-yaml": "^4.1.1",
    "p-queue": "^9.1.0",
    "proper-lockfile": "^4.1.2",
    "yargs": "^18.0.0",
    "zod": "^4.3.6"
  }
}
