# OMG - Oh My God
# Gitignore for Claude Code orchestration plugin

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
.venv/
pip-log.txt

# macOS
.DS_Store
.AppleDouble
.LSOverride

# IDE
.vscode/
.idea/
*.swp
*.swo
*~

# Logs
*.log
logs/

# Test artifacts
.pytest_cache/
.coverage
htmlcov/
*.egg-info/

# Claude Code specific (local dev)
.claude-local/

# Temporary files
*.tmp
*.bak
*.backup
:memory:

# Node
node_modules/
npm-debug.log*
package-lock.json

# OS files
Thumbs.db
desktop.ini

# Local environment
.env
.env.local

# Claude plugin cache (if present in repo workspace)
.claude/plugins/cache/

# Runtime state directories
.oal/
.omg/
.omc/
.sisyphus/

# Credential store
credentials.enc
credentials.meta

# Plugin runtime directories (populated on install/use)
plugins/advanced/agents/
plugins/advanced/skills/
plugins/core/commands/
plugins/core/skills/
build/lib/
build/bdist*/
build/temp*/
