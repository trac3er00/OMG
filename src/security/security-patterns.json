    { "pattern": "\\b(system|assistant|developer)\\s*:", "flags": "i", "label": "role-prefix" },
    { "pattern": "\\b(run|execute|commit|push|apply_patch|edit)\\b", "flags": "i", "label": "action-verb" },
    { "pattern": "<\\s*\\/?(?:system|assistant|user)\\s*>", "flags": "i", "label": "xml-role-tag" },
    { "pattern": "\\[INST\\]|\\[\\/INST\\]", "flags": "i", "label": "inst-token" },
    { "pattern": "###\\s*(?:System|Human|Assistant)\\s*:", "flags": "i", "label": "markdown-role-header" },
    { "pattern": "OVERRIDE\\s*(?:INSTRUCTIONS|SYSTEM)", "flags": "i", "label": "override-system" },
    { "pattern": "disregard\\s+(?:your|previous|all)\\s+(?:instructions|rules)", "flags": "i", "label": "disregard-instructions" },
    { "pattern": "(?:you are|you're)\\s+(?:now|actually|really)\\s+(?:a|an)\\s+", "flags": "i", "label": "role-reassignment" },
    { "pattern": "(?:jailbreak|DAN|AIM|UCAR)\\s*(?:mode|prompt|persona)?", "flags": "i", "label": "jailbreak-mode" },
    { "pattern": "(?:bypass|disable)\\s+(?:safety|guardrails|filters?)", "flags": "i", "label": "safety-bypass-language" }
  ]
