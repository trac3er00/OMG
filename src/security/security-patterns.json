    { "pattern": "\\[SYSTEM\\][\\s\\S]{0,800}\\[\\/SYSTEM\\]", "flags": "i", "label": "bracket-system-tag" },
    { "pattern": "###\\s*(?:System|Human|Assistant)\\s*:", "flags": "i", "label": "markdown-role-header" },
    { "pattern": "###\\s+SYSTEM\\s+PROMPT", "flags": "i", "label": "markdown-system-prompt" },
    { "pattern": "={3,}\\s*SYSTEM\\s*={3,}", "flags": "i", "label": "equals-system-delimiter" }
  ],
  "layer4": [
    { "pattern": "\\bDAN\\b.{0,50}can\\s+do\\s+anything", "flags": "i", "label": "dan-unbounded-capability", "confidence": 0.88 },
    { "pattern": "\\bDAN\\b.{0,100}mode", "flags": "i", "label": "dan-mode", "confidence": 0.86 },
    { "pattern": "you\\s+are\\s+(?:now\\s+)?(?:playing|acting\\s+as)\\s+an?\\s+(?:AI|assistant).{0,50}(?:no|without)\\s+(?:restrictions?|filters?|rules?)", "flags": "i", "label": "act-as-unrestricted", "confidence": 0.9 },
    { "pattern": "pretend\\s+(?:you\\s+)?(?:have\\s+no|don't\\s+have)\\s+(?:restrictions?|rules?|guidelines?)", "flags": "i", "label": "pretend-no-rules", "confidence": 0.88 },
    { "pattern": "as\\s+(?:an?\\s+)?(?:evil|unconstrained|jailbroken|liberated)\\s+(?:AI|assistant|model)", "flags": "i", "label": "evil-unconstrained-persona", "confidence": 0.89 },
    { "pattern": "(?:new\\s+prime\\s+directive|system\\s+override)\\s*:", "flags": "i", "label": "directive-rewrite", "confidence": 0.9 }
