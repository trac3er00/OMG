{
  "version": "1.0.0",
  "description": "Unified injection defense patterns for TypeScript and Python",
  "layer1": [
    { "pattern": "ignore\\s+(all\\s+)?previous(?:\\s+instructions?)?", "flags": "i", "label": "ignore-prev-instructions", "confidence": 0.95 },
    { "pattern": "<\\|im_start\\|>", "flags": "i", "label": "im-start-token", "confidence": 0.99 },
