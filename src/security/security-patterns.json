    { "pattern": "(?:>|>>|tee\\b).{0,120}(?:\\/)?\\omg\\/state\\/", "flags": "i", "label": "state-path-overwrite-attempt", "confidence": 0.93 },
    { "pattern": "\\bcache|state\\s*(?:poison|override|overwrite|tamper)\\b", "flags": "i", "label": "cache-poisoning-language", "confidence": 0.9 },
    { "pattern": "\\boverride\\s*(?:instructions|system|rules?)\\b", "flags": "i", "label": "override-system", "confidence": 0.95 },
    { "pattern": "disregard\\s+(?:your|previous|all)\\s+(?:instructions|rules)", "flags": "i", "label": "disregard-instructions", "confidence": 0.93 },
    { "pattern": "\\b(?:you are|you're)\\s+(?:now|actually|really)\\s+(?:a|an)\\s+", "flags": "i", "label": "role-reassignment", "confidence": 0.9 },
    { "pattern": "(?:jailbreak|DAN|AIM|UCAR)\\s*(?:mode|prompt|persona)?", "flags": "i", "label": "jailbreak-mode", "confidence": 0.92 },
    { "pattern": "(?:bypass|disable)\\s+(?:safety|guardrails|filters?)", "flags": "i", "label": "safety-bypass-language", "confidence": 0.9 },
    { "pattern": "\\b(?:run|execute|commit|push|apply_patch|edit)\\b.{0,40}\\b(?:command|now|immediately|without\\s+question)\\b", "flags": "i", "label": "tooling-command-language", "confidence": 0.72 },
    { "pattern": "(?:comment|hidden|invisible).{0,80}\\b(?:ignore|override|jailbreak|bypass)\\b", "flags": "i", "label": "comment-hidden-instruction", "confidence": 0.86 },
    { "pattern": "pretend\\s+(?:you\\s+)?(?:have\\s+no|don't\\s+have|don't\\s+care\\s+about)\\s+(?:restrictions?|rules?|guidelines?)", "flags": "i", "label": "pretend-no-rules", "confidence": 0.88 },
    { "pattern": "as\\s+(?:an?\\s+)?(?:evil|unconstrained|jailbroken|liberated)\\s+(?:AI|assistant|model)", "flags": "i", "label": "evil-unconstrained-persona", "confidence": 0.89 }
  ],
  "layer2": [
    { "pattern": "<system>[\\s\\S]{0,800}<\\/system>", "flags": "i", "label": "xml-system-tag" },
    { "pattern": "<\\s*\\/?(?:system|assistant|user)\\s*>", "flags": "i", "label": "xml-role-tag" },
