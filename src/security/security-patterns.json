    { "pattern": "(?:^|\\s)SYSTEM\\s*:", "flags": "i", "label": "system-role-token", "confidence": 0.9 },
    { "pattern": "(?:^|\\s)ASSISTANT\\s*:", "flags": "i", "label": "assistant-role-token", "confidence": 0.9 },
